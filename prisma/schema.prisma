// Al Ain Properties - Prisma Schema
// PostgreSQL on Neon (for Vercel serverless compatibility)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Admin User (single owner-managed account) ───
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Property ───
model Property {
  id            String   @id @default(cuid())
  slug          String   @unique
  titleEn       String
  titleAr       String
  descriptionEn String
  descriptionAr String
  type          String
  listingType   String   @default("rent")
  area          String
  addressEn     String?
  addressAr     String?
  latitude      Float?
  longitude     Float?
  price         Int
  bedrooms      Int      @default(0)
  bathrooms     Int      @default(0)
  sizeSqft      Int      @default(0)
  furnished     Boolean  @default(false)
  photos        String   @default("[]")
  videoUrl      String?
  features      String   @default("[]")
  status        String   @default("active")
  featured      Boolean  @default(false)
  views         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  inquiries     PropertyInquiry[]
  viewings      ViewingBooking[]

  @@index([type])
  @@index([listingType])
  @@index([area])
  @@index([status])
  @@index([featured])
}

// ─── Property Inquiry (from contact form / WhatsApp redirect) ───
model PropertyInquiry {
  id          String   @id @default(cuid())
  propertyId  String?
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name        String
  phone       String
  email       String?
  message     String
  source      String   @default("contact_form")
  status      String   @default("new")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([propertyId])
  @@index([status])
}

// ─── Viewing Booking (form data goes to WhatsApp) ───
model ViewingBooking {
  id            String   @id @default(cuid())
  propertyId    String?
  property      Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name          String
  phone         String
  email         String?
  preferredDate String
  preferredTime String
  message       String?
  status        String   @default("new")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([propertyId])
  @@index([status])
}

// ─── News Article ───
model NewsArticle {
  id           String   @id @default(cuid())
  slug         String   @unique
  titleEn      String
  titleAr      String
  excerptEn    String
  excerptAr    String
  contentEn    String
  contentAr    String
  category     String   @default("Market Updates")
  coverImage   String?
  status       String   @default("published")
  views        Int      @default(0)
  publishedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@index([publishedAt])
}

// ─── Site Settings (contact info, social links, etc.) ───
model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
